<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_grn_import_wizard_form" model="ir.ui.view">
        <field name="name">grn.import.wizard.form</field>
        <field name="model">grn.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import GRN Inward Inventory">

                <group>
                    <group string="Upload Excel File">
                        <field name="file_data" filename="file_name" widget="binary"/>
                        <field name="file_name" invisible="1"/>
                    </group>
                    <group string="Instructions">
                        <div class="alert alert-info" role="alert">
                            <p><strong>Expected Excel Format:</strong></p>
                            <ul>
                                <li>Row 1: Title row (ignored)</li>
                                <li>Row 2: Column headers</li>
                                <li>Row 3: Blank (ignored)</li>
                                <li>Row 4+: Data rows</li>
                            </ul>
                            <p><strong>Required columns:</strong> GRN NO., INVOICE DATE,
                            PROJECT CODE, PR NO, PO NUMBER, INVOICE NUMBER,
                            DESCRIPITION, PART NO, PO QTY, RECEIVED QTY, UNIT,
                            RATE, GST, TOTAL AMOUNT, GRAND TOTAL, SUPPLIER</p>
                            <p><strong>Grouping:</strong> All rows with the same GRN NO.
                            are imported as a single Receipt (stock.picking).</p>
                        </div>
                    </group>
                </group>

                <group string="Import Result">
                    <field name="import_log" widget="text"
                           style="font-family: monospace; white-space: pre;"/>
                </group>

                <footer>
                    <button string="Import" name="action_import" type="object" class="btn-primary"/>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>

            </form>
        </field>
    </record>

    <record id="action_grn_import_wizard" model="ir.actions.act_window">
        <field name="name">Import GRN Inventory</field>
        <field name="res_model">grn.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
